---
// Components
import { Image } from 'astro:assets'
import GoldLabel from '@components/GoldLabel.astro'

// SVGs
import Ashi from '@svgs/ashi-certified.svg'

// Types
import type { ImageMetadata } from 'astro'

export interface Props {
  label: string
  paragraph: string
  image: ImageMetadata
  imageAlt: string
  showBadge?: boolean
}

const { label, paragraph, image, imageAlt, showBadge = false } = Astro.props
---

<header class="px-page py-section-sm grid-bg">
  <div class="contained gap-gutter grid items-center md:grid-cols-2">
    <div id="hero-content">
      <GoldLabel text={label} />
      <h1 id="hero-title" class="text-title-lg mb-el-xl font-semibold">
        <slot name="title" />
      </h1>
      <p
        id="hero-paragraph"
        class="text-body-lg text-dark-1 mb-el-lg text-balance"
      >
        {paragraph}
      </p>
      <div class="pt-el-xl gap-el-lg flex">
        <slot name="cta" />
      </div>
    </div>
    <div class="relative aspect-square h-full max-h-140 w-full md:aspect-auto">
      <div
        id="hero-image-container"
        class="inset-shadow h-full w-full overflow-hidden rounded-2xl"
      >
        <Image
          id="hero-image"
          src={image}
          alt={imageAlt}
          class="h-full w-full scale-[1.3] object-cover"
        />
      </div>
      {
        showBadge && (
          <Ashi
            id="hero-ashi"
            class="absolute -bottom-6 left-1/2 z-20 h-26 -translate-x-1/2 lg:-left-8 lg:translate-x-0"
          />
        )
      }
    </div>
  </div>
</header>

<script>
  import '@lib/hero-animation'
</script>
