---
// Components
import Button from '@components/Button.astro'

// SVGs
import Logo from '@svgs/logo.svg'
import Lettermark from '@svgs/lettermark.svg'
import ArrowRight from '@svgs/arrow-right.svg'
import NavbarLink from './NavbarLink.astro'

const url = Astro.url.pathname
---

<nav
  class="px-page gap-gutter flex h-16 items-center justify-between bg-white py-4 md:h-20"
>
  <a href="/" class="">
    <Logo class="mr-2 inline-block w-8" />
    <Lettermark class="mt-1 inline-block h-6" />
  </a>
  <ul class="gap-gutter mt-1 flex items-center justify-center">
    <NavbarLink url="/" label="Home" />
    <NavbarLink url="/about" label="About" />
    <NavbarLink url="/services" label="Services" />
    <NavbarLink url="/blog" label="Blog" />
    <NavbarLink url="/contact" label="Contact" />
  </ul>
  <Button>Request Consultation <ArrowRight class="size-6" /></Button>
</nav>
