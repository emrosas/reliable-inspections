---
import { tv, type VariantProps } from 'tailwind-variants/lite'
import type { HTMLAttributes } from 'astro/types'

const button = tv({
  base: 'inline-flex items-center justify-center active:opacity-80 cursor-pointer transition shrink-0 text-center',
  variants: {
    intent: {
      primary: 'bg-linear-to-tr from-green-5 to-green-3 text-white',
      secondary: '',
      outline: '',
      ghost: '',
    },
    size: {
      lg: '',
      md: 'text-body-md py-el-md px-el-lg gap-el-xs rounded-sm',
      sm: '',
    },
  },
  defaultVariants: {
    intent: 'primary',
    size: 'md',
  },
})

type ComponentStyles = VariantProps<typeof button>

type ButtonProps = {
  href?: undefined
  type?: 'button' | 'submit' | 'reset'
} & HTMLAttributes<'button'>

type AnchorProps = {
  href: string
  type?: undefined
} & HTMLAttributes<'a'>

export type Props =
  | (ButtonProps & ComponentStyles)
  | (AnchorProps & ComponentStyles)

const { intent, size, class: className, href, ...rest } = Astro.props as Props

const Element = href ? 'a' : 'button'
---

<Element {...rest} href={href} class={button({ intent, size, className })}
  ><slot /></Element
>
