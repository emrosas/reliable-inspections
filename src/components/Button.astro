---
import { tv, type VariantProps } from 'tailwind-variants/lite'
import type { HTMLAttributes } from 'astro/types'

const button = tv({
  base: 'inline-flex items-center justify-center rounded-lg active:opacity-80 cursor-pointer transition shrink-0 text-center font-medium',
  variants: {
    intent: {
      primary: 'bg-linear-to-tr from-green-5 to-green-4 text-white',
      secondary: 'bg-brand-100 hover:bg-brand-200 text-brand-900',
      outline:
        'bg-transparent hover:bg-brand-500/10 border border-brand-500 text-brand-500',
      ghost: 'bg-transparent hover:bg-brand-500/10 text-brand-500',
    },
    size: {
      lg: 'text-body-lg py-3 px-6 gap-el-sm',
      md: 'text-body-md py-2 px-4 gap-el-xs',
      sm: 'text-body-sm py-1.5 px-3 gap-[0.375rem]',
    },
  },
  defaultVariants: {
    intent: 'primary',
    size: 'md',
  },
})

type ComponentStyles = VariantProps<typeof button>

type ButtonProps = {
  href?: undefined
  type?: 'button' | 'submit' | 'reset'
} & HTMLAttributes<'button'>

type AnchorProps = {
  href: string
  type?: undefined
} & HTMLAttributes<'a'>

export type Props =
  | (ButtonProps & ComponentStyles)
  | (AnchorProps & ComponentStyles)

const { intent, size, class: className, href, ...rest } = Astro.props as Props

const Element = href ? 'a' : 'button'
---

<Element {...rest} href={href} class={button({ intent, size, className })}
  ><slot /></Element
>
