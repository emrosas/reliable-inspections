---
// Components
import Layout from '@layouts/Layout.astro'
import { Image } from 'astro:assets'
import Button from '@/components/Button.astro'
import GoldLabel from '@/components/GoldLabel.astro'
import PageHero from '@components/PageHero.astro'
import ServiceCard from '@components/ServiceCard.astro'
import CtaSection from '@components/CTA.astro'
import FaqSection from '@components/FAQ.astro'

// Helpers
import { getCollection } from 'astro:content'

// Images
import hero from '@images/hero.jpg'
import whyUs from '@images/why-us.jpg'
import home from '@images/home.jpg'

// SVGs
import ArrowRight from '@svgs/arrow-right.svg'
import MagnifierIcon from '@svgs/magnifier.svg'
import CertifiedIcon from '@svgs/certified.svg'
import ReportIcon from '@svgs/report.svg'
import StarIcon from '@svgs/star.svg'
import NinetyDayIcon from '@svgs/90-day.svg'
import SewerGuardIcon from '@svgs/sewer-guard.svg'
import MoldSafeIcon from '@svgs/mold-safe.svg'
import PlatinumIcon from '@svgs/platinum.svg'
import ninetyDayImg from '@images/90-day.png'
import sewerGuardImg from '@images/sewer-guard.png'
import moldSafeImg from '@images/mold-safe.png'
import platinumImg from '@images/platinum.png'

const services = await getCollection('services')
---

<Layout
  title="Home Inspection Services in Kentucky | Reliable Inspections"
  description="Certified home and commercial property inspectors serving Mount Washington, Louisville, Lexington, Frankfort, and all of Kentucky. 4,200+ inspections. InterNACHI-certified. Digital reports in 24 hrs."
>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'How much does a home inspection cost in Kentucky?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Typically between $300 and $500, depending on the size and age of the home. Reliable Inspections provides transparent, flat-rate pricing with no hidden fees.',
          },
        },
        {
          '@type': 'Question',
          name: 'How long does a home inspection take?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Most inspections take between 2 and 4 hours. Larger or older homes may take longer. You\'ll receive your full digital report within 24 hours of completion.',
          },
        },
        {
          '@type': 'Question',
          name: 'What does a home inspection include?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'We inspect all major systems including the roof, foundation, HVAC, plumbing, electrical, and more. Our standard inspection includes thermal imaging and moisture detection at no extra cost.',
          },
        },
        {
          '@type': 'Question',
          name: 'Who hires the home inspector?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Typically the buyer of the home chooses and hires the home inspector. There are occasions where the seller has a pre-listing inspection done to identify issues before putting the home on the market.',
          },
        },
        {
          '@type': 'Question',
          name: 'Should I be present during the inspection?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'We strongly encourage it. Being present allows you to ask questions in real time and get a firsthand understanding of the property\'s condition from our inspector.',
          },
        },
      ],
    })}
  />
  <main>
    <!-- Hero -->
    <PageHero
      label="The Reliable Edge"
      paragraph="Thorough, architectural-grade inspections for Kentucky homeowners and investors. We see what others miss, ensuring your foundation is as solid as your future."
      image={hero}
      imageAlt="A Kentucky home seen from outside."
      showBadge
    >
      <Fragment slot="title">
        Your Peace of Mind, <span class="text-green-1">Our Guarantee</span>
      </Fragment>
      <Fragment slot="cta">
        <Button>
          Request Consultation
          <ArrowRight class="size-6" />
        </Button>
        <Button intent="secondary">Read More</Button>
      </Fragment>
    </PageHero>

    <!-- Services -->
    <section id="services" class="px-page py-section-md bg-light-1">
      <div class="gap-el-lg mb-section-sm contained grid md:grid-cols-12">
        <div data-animate-stagger="" class="md:col-span-7">
          <span class="text-body-sm text-warm-4 mb-el-sm uppercase">
            Precision Services
          </span>
          <h2 class="text-title-md font-semibold">Inspection Solutions</h2>
        </div>
        <p data-animate class="text-dark-1 text-body-md mt-auto md:col-span-5">
          Tailored assessments for every stage of property ownership, from
          historic downtown lofts to sprawling suburban estates.
        </p>
      </div>
      <ul
        class="gap-gutter contained grid grid-cols-[repeat(auto-fit,minmax(320px,1fr))]"
      >
        {
          services.map((service) => (
            <ServiceCard
              title={service.data.title}
              description={service.data.description}
              image={service.data.image}
            />
          ))
        }
      </ul>

      <!-- Warranties -->
      <div class="contained mt-section-sm">
        <h2
          data-animate
          class="text-title-sm mb-section-sm text-center font-semibold"
        >
          Our Included <span class="text-green-1">FREE</span> Warranties.
        </h2>
        <ul
          class="gap-gutter grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))]"
        >
          <!-- 90-Day Warranty -->
          <li
            data-animate
            class="pb-el-xl px-el-lg mt-el-xl relative flex flex-col items-center rounded-xl border-2 bg-white pt-10 text-center"
            style="border-color: #A42536;"
          >
            <NinetyDayIcon class="absolute -top-7 size-14 rounded-full" />
            <Image
              src={ninetyDayImg}
              alt="90-Day Warranty"
              class="mb-el-md h-12 object-contain"
            />
            <p class="text-body-sm text-dark-1">
              You need a professional you can rely on even after the job is
              complete. That&apos;s why we support all our inspections with a
              90-Day Limited Structural and Mechanical Warranty.
            </p>
          </li>

          <!-- SewerGard -->
          <li
            data-animate
            class="pb-el-xl px-el-lg mt-el-xl relative flex flex-col items-center rounded-xl border-2 bg-white pt-10 text-center"
            style="border-color: #FBBF11;"
          >
            <SewerGuardIcon class="absolute -top-7 size-14 rounded-full" />
            <Image
              src={sewerGuardImg}
              alt="SewerGard"
              class="mb-el-md h-12 object-contain"
            />
            <p class="text-body-sm text-dark-1">
              Offered for a period of 90 days following the date of the
              inspection, SewerGard covers your water line and sewer against
              failure due to normal wear and tear, giving you peace of mind.
            </p>
          </li>

          <!-- MoldSafe -->
          <li
            data-animate
            class="pb-el-xl px-el-lg mt-el-xl relative flex flex-col items-center rounded-xl border-2 bg-white pt-10 text-center"
            style="border-color: #DD5631;"
          >
            <MoldSafeIcon class="absolute -top-7 size-14 rounded-full" />
            <Image
              src={moldSafeImg}
              alt="MoldSafe"
              class="mb-el-md h-12 object-contain"
            />
            <p class="text-body-sm text-dark-1">
              For up to 90 days after the inspection date, if you move into your
              new home and discover mold that was not identified during the
              inspection, you are covered for remediation.
            </p>
          </li>

          <!-- Platinum -->
          <li
            data-animate
            class="pb-el-xl px-el-lg mt-el-xl relative flex flex-col items-center rounded-xl border-2 bg-white pt-10 text-center"
            style="border-color: #296CA3;"
          >
            <PlatinumIcon class="absolute -top-7 size-14 rounded-full" />
            <Image
              src={platinumImg}
              alt="Platinum Roof Protection Plan"
              class="mb-el-md h-12 object-contain"
            />
            <p class="text-body-sm text-dark-1">
              Handles the repair of leaks to your home&apos;s roof for a period
              of 5 years following the date of the inspection.
            </p>
          </li>
        </ul>
      </div>
    </section>

    <!-- Why Us -->
    <section id="why-us" class="py-section-md px-page">
      <div class="gap-gutter mx-auto grid max-w-7xl md:grid-cols-12">
        <div class="md:pr-gutter md:col-span-6 lg:col-span-5 lg:col-start-2">
          <div
            data-animate="fade-in"
            class="inset-shadow aspect-square h-full max-h-140 w-full overflow-hidden rounded-2xl md:aspect-auto"
          >
            <Image
              id="why-us-image"
              src={whyUs}
              alt="Why Us"
              class="h-full w-full scale-[1.3] object-cover"
            />
          </div>
        </div>
        <div class="py-el-xl md:col-span-6 lg:col-span-5">
          <GoldLabel data-animate text="The Reliable Edge" />
          <h2 data-animate class="text-title-md mb-el-xl font-semibold">
            Built on Integrity and <span class="text-green-1">Precision.</span>
          </h2>
          <ul data-animate-stagger class="gap-el-xl flex flex-col">
            <li class="flex">
              <div
                class="bg-background-alt mr-el-xl flex size-12 shrink-0 items-center justify-center rounded-lg"
              >
                <MagnifierIcon class="text-green-3 size-9" />
              </div>
              <div>
                <h3 class="text-body-md mb-el-sm leading-none font-semibold">
                  Industry Standards
                </h3>
                <p class="text-body-sm text-dark-1">
                  Our protocols exceed state requirements, utilizing thermal
                  imaging and moisture detection as standard practices.
                </p>
              </div>
            </li>
            <li class="flex">
              <div
                class="bg-background-alt mr-el-xl flex size-12 shrink-0 items-center justify-center rounded-lg"
              >
                <CertifiedIcon class="text-green-3 size-9" />
              </div>
              <div>
                <h3 class="text-body-md mb-el-sm leading-none font-semibold">
                  Certified Professionals
                </h3>
                <p class="text-body-sm text-dark-1">
                  Every inspector on our team is InterNACHI certified and has a
                  background in structural engineering or trades.
                </p>
              </div>
            </li>
            <li class="flex">
              <div
                class="bg-background-alt mr-el-xl flex size-12 shrink-0 items-center justify-center rounded-lg"
              >
                <ReportIcon class="text-green-3 size-9" />
              </div>
              <div>
                <h3 class="text-body-md mb-el-sm leading-none font-semibold">
                  Detailed Reporting
                </h3>
                <p class="text-body-sm text-dark-1">
                  Receive a digital, interactive report within 24 hours
                  featuring high- res video clips and a simplified summary for
                  quick reading.
                </p>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="px-page py-section-md bg-green-5">
      <div data-animate-stagger class="contained mb-section-sm text-center">
        <h2 class="text-title-md mb-el-md text-light-1 font-semibold">
          Trusted by Kentucky's Best
        </h2>
        <p class="text-body-md text-light-4">
          Real experiences from homeowners, buyers, and real estate
          professionals across the Commonwealth.
        </p>
      </div>
      <ul
        class="contained¿ gap-gutter pt-el-lg grid grid-cols-[repeat(auto-fit,minmax(300px,1fr))]"
      >
        <li
          data-animate
          data-animate-stagger
          class="p-el-xl gap-el-lg border-green-2 bg-green-4/50 flex flex-col rounded-xl border"
        >
          <div class="gap-el-xs flex">
            <StarIcon class="text-warm-1 size-5" />
            <StarIcon class="text-warm-1 size-5" />
            <StarIcon class="text-warm-1 size-5" />
            <StarIcon class="text-warm-1 size-5" />
            <StarIcon class="text-warm-1 size-5" />
          </div>
          <p class="text-body-md text-light-4 font-light">
            "The level of detail in their digital report saved us from a $20,000
            foundation issue. I won't buy another property in Lexington without
            calling Reliable first."
          </p>
          <div class="gap-el-lg flex items-center">
            <div
              class="bg-light-3 size-12 shrink-0 overflow-hidden rounded-full"
            >
              <Image
                src={home}
                alt="David Henderson"
                class="h-full w-full object-cover"
              />
            </div>
            <div>
              <p class="text-body-sm text-light-1 font-semibold">
                David Henderson
              </p>
              <p class="text-body-xs text-light-4 uppercase">
                Homeowner, Lexington
              </p>
            </div>
          </div>
        </li>
        <li
          data-animate
          data-animate-stagger
          class="p-el-xl gap-el-lg border-green-2 bg-green-4/50 flex flex-col rounded-xl border"
        >
          <div class="gap-el-xs flex">
            <StarIcon class="text-warm-1 size-5" />
            <StarIcon class="text-warm-1 size-5" />
            <StarIcon class="text-warm-1 size-5" />
            <StarIcon class="text-warm-1 size-5" />
            <StarIcon class="text-warm-1 size-5" />
          </div>
          <p class="text-body-md text-light-4 font-light">
            "As a realtor, I need inspectors who are thorough but not alarmist.
            Reliable Inspections provides the most balanced and professional
            reports in the business."
          </p>
          <div class="gap-el-lg flex items-center">
            <div
              class="bg-light-3 size-12 shrink-0 overflow-hidden rounded-full"
            >
              <Image
                src={home}
                alt="Sarah Miller"
                class="h-full w-full object-cover"
              />
            </div>
            <div>
              <p class="text-body-sm text-light-1 font-semibold">
                Sarah Miller
              </p>
              <p class="text-body-xs text-light-4 uppercase">
                Real Estate Pro, Louisville
              </p>
            </div>
          </div>
        </li>
        <li
          data-animate
          data-animate-stagger
          class="p-el-xl gap-el-lg border-green-2 bg-green-4/50 flex flex-col rounded-xl border"
        >
          <div class="gap-el-xs flex">
            <StarIcon class="text-warm-1 size-5" />
            <StarIcon class="text-warm-1 size-5" />
            <StarIcon class="text-warm-1 size-5" />
            <StarIcon class="text-warm-1 size-5" />
            <StarIcon class="text-warm-1 size-5" />
          </div>
          <p class="text-body-md text-light-4 font-light">
            "Impressive technology and professionalism. Their thermal imaging
            caught a hidden pipe leak that was invisible to the naked eye.
            Highly recommend."
          </p>
          <div class="gap-el-lg flex items-center">
            <div
              class="bg-light-3 size-12 shrink-0 overflow-hidden rounded-full"
            >
              <Image
                src={home}
                alt="Marcus Chen"
                class="h-full w-full object-cover"
              />
            </div>
            <div>
              <p class="text-body-sm text-light-1 font-semibold">Marcus Chen</p>
              <p class="text-body-xs text-light-4 uppercase">
                Property Investor, Frankfort
              </p>
            </div>
          </div>
        </li>
      </ul>
    </section>

    <CtaSection />

    <FaqSection />
  </main>
</Layout>

<script>
  import '@lib/home'
</script>
