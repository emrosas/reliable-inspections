---
//Components
import Layout from '@layouts/Layout.astro'
import CtaSection from '@components/CTA.astro'

//Helpers
import { Image } from 'astro:assets'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.status === 'published')
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content } = await render(post)

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
})
---

<Layout title={post.data.title} description={post.data.description}>
  <main class="py-section-md px-page">
    <div class="contained">
      <div class="grid md:grid-cols-12">
        <div class="md:col-span-8 md:col-start-3">
          <!-- Header -->
          <header class="mb-el-xl">
            <h1 class="text-title-lg mb-el-md font-semibold">
              {post.data.title}
            </h1>
            <p class="text-body-md text-dark-1 mb-el-lg">
              {post.data.description}
            </p>
            <div class="gap-el-sm text-body-sm text-blue-1 flex items-center">
              <time datetime={post.data.date.toISOString()}>
                {formattedDate}
              </time>
              <span aria-hidden="true">&bull;</span>
              <span>{post.data.readTime}</span>
            </div>
          </header>

          <!-- Hero Image -->
          <div class="my-el-xl">
            <Image
              src={post.data.image}
              alt={post.data.imageAlt}
              class="aspect-video w-full rounded-xl object-cover"
            />
          </div>

          <!-- Body -->
          <div
            class="[&_h2]:text-title-sm [&_h2]:text-dark-3 [&_h2]:mb-el-md [&_h2]:mt-el-xl [&_h3]:text-body-lg [&_h3]:text-dark-3 [&_h3]:mb-el-sm [&_h3]:mt-el-lg [&_p]:text-body-md [&_p]:text-dark-1 [&_p]:mb-el-md [&_ul]:pl-el-xl [&_ul]:text-body-md [&_ul]:text-dark-1 [&_ul]:mb-el-md [&_li]:mb-el-sm [&_h2]:font-semibold [&_h3]:font-semibold [&_ul]:list-disc"
          >
            <Content />
          </div>
        </div>
      </div>
    </div>
  </main>

  <CtaSection />
</Layout>
