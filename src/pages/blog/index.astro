---
//Components
import Layout from '@layouts/Layout.astro'
import { Image } from 'astro:assets'
import BannerHero from '@components/BannerHero.astro'
import CtaSection from '@components/CTA.astro'

//Helpers
import { getCollection } from 'astro:content'

// Images
import blog from '@images/blog.jpg'

const posts = await getCollection('blog')
const sortedPosts = posts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
)
---

<Layout
  title="Blog"
  description="Insights, guides, and expert advice on home and commercial property inspections from the Reliable Inspections team."
>
  <main>
    <!-- Hero -->
    <BannerHero
      label="Connect with us."
      image={blog}
      imageAlt="Kentucky homes at sunset."
    >
      <Fragment slot="title">
        We are here for Kentucky <span class="text-warm-1"
          >Property Owners.</span
        >
      </Fragment>
      <div
        class="gap-el-sm px-el-lg py-el-md mx-auto flex max-w-md items-center rounded-lg bg-white"
      >
        <svg
          class="text-dark-1 size-5 shrink-0"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"
          ></path>
        </svg>
        <input
          id="blog-search"
          type="search"
          placeholder="Search articles, guides, or laws..."
          class="text-body-sm text-dark-3 placeholder:text-dark-1 w-full bg-transparent focus:outline-none"
        />
      </div>
    </BannerHero>

    <!-- Posts Grid -->
    <section class="px-page py-section-md">
      <div class="contained">
        <ul
          class="gap-gutter grid grid-cols-[repeat(auto-fill,minmax(320px,1fr))]"
        >
          {
            sortedPosts.map((post) => (
              <li
                class="border-light-4 flex flex-col overflow-hidden rounded-xl border"
                data-title={post.data.title.toLowerCase()}
                data-description={post.data.description.toLowerCase()}
              >
                <Image
                  src={post.data.image}
                  alt={post.data.imageAlt}
                  class="aspect-video w-full object-cover"
                />
                <div class="p-el-xl gap-el-md flex flex-1 flex-col">
                  <div class="gap-el-sm text-body-sm text-green-1 flex items-center">
                    <time datetime={post.data.date.toISOString()}>
                      {post.data.date.toLocaleDateString('en-US', {
                        month: 'short',
                        day: 'numeric',
                        year: 'numeric',
                      })}
                    </time>
                    <span aria-hidden="true">&bull;</span>
                    <span>{post.data.readTime}</span>
                  </div>
                  <h2 class="text-body-lg leading-snug font-semibold">
                    {post.data.title}
                  </h2>
                  <p class="text-body-sm text-dark-1 flex-1">
                    {post.data.description}
                  </p>
                  <a
                    href={`/blog/${post.id}`}
                    class="text-body-sm text-green-1 mt-el-sm inline-block font-medium underline-offset-2 hover:underline"
                  >
                    Read article &rarr;
                  </a>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <CtaSection />
  </main>
</Layout>

<script>
  const input = document.getElementById('blog-search') as HTMLInputElement
  const posts = document.querySelectorAll<HTMLLIElement>('[data-title]')

  input?.addEventListener('input', () => {
    const query = input.value.toLowerCase().trim()
    posts.forEach((post) => {
      const matches =
        !query ||
        post.dataset.title?.includes(query) ||
        post.dataset.description?.includes(query)
      post.style.display = matches ? '' : 'none'
    })
  })
</script>
