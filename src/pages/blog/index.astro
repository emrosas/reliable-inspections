---
//Components
import Layout from '@layouts/Layout.astro'
import BannerHero from '@components/BannerHero.astro'
import CtaSection from '@components/CTA.astro'

//Helpers
import { getCollection } from 'astro:content'

// Images
import blogImage from '@images/blog.png'

const posts = await getCollection('blog')
const sortedPosts = posts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
)
---

<Layout
  title="Blog"
  description="Insights, guides, and expert advice on home and commercial property inspections from the Reliable Inspections team."
>
  <main>
    <!-- Hero -->
    <BannerHero
      label="Connect with us."
      image={blogImage}
      imageAlt="Kentucky homes at sunset."
    >
      <Fragment slot="title">
        We are here for Kentucky <span class="text-warm-1">Property Owners.</span>
      </Fragment>
      <div class="mx-auto flex max-w-md items-center gap-el-sm rounded-lg bg-white px-el-lg py-el-md">
        <svg class="text-dark-1 size-5 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
        </svg>
        <input
          type="search"
          placeholder="Search articles, guides, or laws..."
          class="text-body-sm text-dark-3 placeholder:text-dark-1 w-full bg-transparent focus:outline-none"
        />
      </div>
    </BannerHero>

    <!-- Posts Grid -->
    <section class="px-page py-section-md">
      <div class="contained">
        <ul class="gap-gutter grid grid-cols-[repeat(auto-fill,minmax(320px,1fr))]">
          {
            sortedPosts.map((post) => (
              <li class="flex flex-col rounded-xl border border-light-4 overflow-hidden">
                <div class="p-el-xl flex flex-col flex-1 gap-el-md">
                  <div class="flex items-center gap-el-sm text-body-sm text-green-1">
                    <time datetime={post.data.date.toISOString()}>
                      {post.data.date.toLocaleDateString('en-US', {
                        month: 'short',
                        day: 'numeric',
                        year: 'numeric',
                      })}
                    </time>
                    <span aria-hidden="true">&bull;</span>
                    <span>{post.data.readTime}</span>
                  </div>
                  <h2 class="text-body-lg font-semibold leading-snug">
                    {post.data.title}
                  </h2>
                  <p class="text-body-sm text-dark-1 flex-1">
                    {post.data.description}
                  </p>
                  <a
                    href={`/blog/${post.id}`}
                    class="text-body-sm text-green-1 font-medium underline-offset-2 hover:underline mt-el-sm inline-block"
                  >
                    Read article &rarr;
                  </a>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <CtaSection />
  </main>
</Layout>
