---
// Components
import Layout from '@layouts/Layout.astro'
import BannerHero from '@components/BannerHero.astro'
import ContactForm from '@components/svelte/ContactForm.svelte'

// Images
import contactImage from '@images/contact.jpg'

// SVGs
import HomeIcon from '@svgs/home.svg'
import PhoneIcon from '@svgs/phone.svg'
import MailIcon from '@svgs/mail.svg'
---

<Layout
  title="Schedule a Home Inspection in Kentucky | Reliable Inspections"
  description="Contact Reliable Inspections to schedule a certified home or commercial property inspection in Mount Washington, Louisville, Lexington, or anywhere in Kentucky. Call (502) 901-8427."
>
  <main>
    <!-- Hero -->
    <BannerHero
      label="Connect with us."
      image={contactImage}
      imageAlt="A Kentucky property seen from the exterior."
    >
      <Fragment slot="title">
        Get in <span class="text-warm-1">Touch.</span>
      </Fragment>
      <p class="text-body-lg text-light-4 mx-auto max-w-3xl text-balance">
        Whether you're buying your first home or managing a commercial
        portfolio, our precision inspections provide the clarity you need.
      </p>
    </BannerHero>

    <!-- Contact -->
    <section class="px-page py-section-md">
      <div class="contained gap-gutter grid md:grid-cols-12">
        <!-- Left: contact information -->
        <div class="md:col-span-5">
          <h2 class="text-title-sm mb-el-md font-semibold">
            Contact Information
          </h2>
          <p class="text-body-md text-dark-1 mb-el-xl">
            Our team is active across the Bluegrass State. Reach out directly or
            visit our Lexington headquarters.
          </p>
          <ul class="gap-el-lg flex flex-col">
            <li class="gap-el-md flex items-start">
              <div
                class="bg-background-alt flex size-10 shrink-0 items-center justify-center rounded-lg"
              >
                <HomeIcon class="text-green-3 size-5" />
              </div>
              <div>
                <p class="text-body-sm font-semibold">Address:</p>
                <p class="text-body-sm text-dark-1">
                  436 Laverne court Mount Washington Ky. 40047
                </p>
              </div>
            </li>
            <li class="gap-el-md flex items-start">
              <div
                class="bg-background-alt flex size-10 shrink-0 items-center justify-center rounded-lg"
              >
                <PhoneIcon class="text-green-3 size-5" />
              </div>
              <div>
                <p class="text-body-sm font-semibold">Phone:</p>
                <a
                  href="tel:+15029018427"
                  class="text-body-sm text-dark-1 hover:underline"
                  >+1 (502) 901-8427</a
                >
              </div>
            </li>
            <li class="gap-el-md flex items-start">
              <div
                class="bg-background-alt flex size-10 shrink-0 items-center justify-center rounded-lg"
              >
                <MailIcon class="text-green-3 size-5" />
              </div>
              <div>
                <p class="text-body-sm font-semibold">Email:</p>
                <a
                  href="mailto:mike@myreliablehomeinspections.com"
                  class="text-body-sm text-dark-1 hover:underline"
                  >mike@myreliablehomeinspections.com</a
                >
              </div>
            </li>
          </ul>
        </div>

        <!-- Right: contact form -->
        <div class="md:col-span-7">
          <ContactForm client:load />
        </div>
      </div>
    </section>
  </main>
</Layout>
