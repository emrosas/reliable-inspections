---
//Components
import Layout from '@layouts/Layout.astro'
import Button from '@components/Button.astro'
---

<Layout
  title="Contact Us"
  description="Get in touch with Reliable Inspections to schedule your home or commercial property inspection across Kentucky."
>
  <main>
    <!-- Header -->
    <header class="px-page py-section-md bg-light-1">
      <div class="contained grid gap-gutter md:grid-cols-12">
        <div class="md:col-span-8 md:col-start-3 text-center">
          <span class="text-body-sm text-warm-4 mb-el-sm uppercase inline-block">
            Get in Touch
          </span>
          <h1 class="text-title-lg mb-el-lg font-semibold">
            Contact Us
          </h1>
          <p class="text-body-md text-dark-1">
            Ready to schedule an inspection or have questions? Fill out the form
            below and a member of our team will get back to you within one
            business day.
          </p>
        </div>
      </div>
    </header>

    <!-- Contact Form -->
    <section class="px-page py-section-md">
      <div class="contained grid gap-gutter md:grid-cols-12">
        <div class="md:col-span-8 md:col-start-3">
          <form
            class="gap-el-lg flex flex-col"
            action="#"
            method="POST"
          >
            <!-- Name -->
            <div class="gap-el-sm flex flex-col">
              <label
                for="name"
                class="text-body-sm font-medium text-dark-3"
              >
                Full Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Jane Smith"
                class="rounded-sm border border-light-4 bg-white px-el-lg py-el-md text-body-md text-dark-3 placeholder:text-dark-1 focus:border-green-1 focus:outline-none transition"
              />
            </div>

            <!-- Email -->
            <div class="gap-el-sm flex flex-col">
              <label
                for="email"
                class="text-body-sm font-medium text-dark-3"
              >
                Email Address
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="jane@example.com"
                class="rounded-sm border border-light-4 bg-white px-el-lg py-el-md text-body-md text-dark-3 placeholder:text-dark-1 focus:border-green-1 focus:outline-none transition"
              />
            </div>

            <!-- Phone (optional) -->
            <div class="gap-el-sm flex flex-col">
              <label
                for="phone"
                class="text-body-sm font-medium text-dark-3"
              >
                Phone Number <span class="text-dark-1 font-normal">(optional)</span>
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                placeholder="(555) 555-5555"
                class="rounded-sm border border-light-4 bg-white px-el-lg py-el-md text-body-md text-dark-3 placeholder:text-dark-1 focus:border-green-1 focus:outline-none transition"
              />
            </div>

            <!-- Message -->
            <div class="gap-el-sm flex flex-col">
              <label
                for="message"
                class="text-body-sm font-medium text-dark-3"
              >
                Message
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="6"
                placeholder="Tell us about the property and what you're looking for..."
                class="rounded-sm border border-light-4 bg-white px-el-lg py-el-md text-body-md text-dark-3 placeholder:text-dark-1 focus:border-green-1 focus:outline-none transition resize-none"
              ></textarea>
            </div>

            <!-- Submit -->
            <div>
              <Button type="submit">Send Message</Button>
            </div>
          </form>
        </div>
      </div>
    </section>
  </main>
</Layout>
