---
//Components
import Layout from '@layouts/Layout.astro'
import FaqSection from '@components/FAQ.astro'
import CtaSection from '@components/CTA.astro'
---

<Layout
  title="About Us"
  description="Learn more about Reliable Inspections — Kentucky's most trusted team of certified home and commercial inspectors."
>
  <main>
    <!-- Hero -->
    <header class="px-page py-section-md bg-light-1">
      <div class="contained grid gap-gutter md:grid-cols-12">
        <div class="md:col-span-8 md:col-start-3 text-center">
          <span class="text-body-sm text-warm-4 mb-el-sm uppercase inline-block">
            Our Story
          </span>
          <h1 class="text-title-lg mb-el-lg font-semibold">
            About Reliable Inspections
          </h1>
          <p class="text-body-md text-dark-1">
            Founded in Lexington, Kentucky, Reliable Inspections was built on a
            simple belief: every property buyer and owner deserves complete,
            honest information. Our InterNACHI-certified inspectors bring
            backgrounds in structural engineering and the trades to every
            inspection — ensuring you get the most thorough assessment available
            in the Commonwealth.
          </p>
        </div>
      </div>
    </header>

    <!-- Mission -->
    <section class="px-page py-section-md">
      <div class="contained grid gap-gutter md:grid-cols-12">
        <div class="md:col-span-5">
          <h2 class="text-title-md mb-el-lg font-semibold">
            Our Mission
          </h2>
          <p class="text-body-md text-dark-1 mb-el-lg">
            We set out to raise the standard for property inspections across
            Kentucky. That means going beyond a checklist — we use thermal
            imaging and moisture detection on every inspection, deliver
            interactive digital reports within 24 hours, and stay available to
            answer your questions long after the inspection is done.
          </p>
          <p class="text-body-md text-dark-1">
            From first-time homebuyers in Louisville to commercial developers in
            Frankfort, we serve clients across the state with the same level of
            care and precision.
          </p>
        </div>
        <div class="md:col-span-6 md:col-start-7">
          <div class="rounded-2xl bg-light-1 p-el-xl h-full">
            <h3 class="text-body-lg mb-el-lg font-semibold">By the Numbers</h3>
            <ul class="gap-el-xl flex flex-col">
              <li class="border-b border-light-4 pb-el-xl">
                <p class="text-title-md font-semibold text-green-1">2,400+</p>
                <p class="text-body-sm text-dark-1">Inspections completed across Kentucky</p>
              </li>
              <li class="border-b border-light-4 pb-el-xl">
                <p class="text-title-md font-semibold text-green-1">24 hrs</p>
                <p class="text-body-sm text-dark-1">Average report delivery time</p>
              </li>
              <li>
                <p class="text-title-md font-semibold text-green-1">100%</p>
                <p class="text-body-sm text-dark-1">InterNACHI-certified inspector team</p>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <FaqSection />

    <CtaSection />
  </main>
</Layout>
