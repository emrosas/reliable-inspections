---
// Components
import Layout from '@layouts/Layout.astro'
import Button from '@components/Button.astro'
import GoldLabel from '@components/GoldLabel.astro'
import PageHero from '@components/PageHero.astro'
import FaqSection from '@components/FAQ.astro'
import CtaSection from '@components/CTA.astro'

// Images
import about from '@images/about.jpg'

// SVGs
import ArrowRight from '@svgs/arrow-right.svg'
import IntegrityIcon from '@svgs/integrity.svg'
import PrecisionIcon from '@svgs/precision.svg'
import CareIcon from '@svgs/care.svg'
---

<Layout
  title="About Us | Certified Home Inspectors in Kentucky | Reliable Inspections"
  description="Learn about Reliable Inspections — Kentucky's trusted InterNACHI-certified home and commercial inspection team based in Mount Washington, KY. 4,200+ inspections completed."
>
  <main>
    <!-- Hero -->
    <PageHero
      label="Our Story"
      paragraph="We provide more than just a checklist. We deliver the peace of mind that comes from meticulous, architecturally-informed property evaluations across the Bluegrass State."
      image={about}
      imageAlt="The Reliable Inspections team on site."
    >
      <Fragment slot="title">
        Our mission is to Elevate
        <span class="text-blue-1"> Property Standards. </span>
      </Fragment>
      <Fragment slot="cta">
        <Button href="/contact"> Get a FREE Quote </Button>
      </Fragment>
    </PageHero>

    <!-- Our Story -->
    <section class="px-page py-section-md">
      <div class="contained gap-gutter grid md:grid-cols-12">
        <!-- Left: title, description, stat cards -->
        <div class="md:col-span-5">
          <h2 data-animate class="text-title-md mb-el-lg font-semibold">
            Our Story
          </h2>
          <p data-animate class="text-body-md text-dark-1 mb-el-xl">
            We seek to provide you with insights on your properties by using
            industry standards.
          </p>
          <ul data-animate-stagger class="gap-gutter grid grid-cols-2">
            <li class="border-light-3 bg-light-1 p-el-lg rounded-xl border">
              <p class="text-title-sm text-blue-4 mb-el-xs font-semibold">
                15+
              </p>
              <p class="text-body-xs text-dark-1 tracking-wide uppercase">
                Years Experience
              </p>
            </li>
            <li class="border-light-3 bg-light-1 p-el-lg rounded-xl border">
              <p class="text-title-sm text-blue-4 mb-el-xs font-semibold">
                99.8
              </p>
              <p class="text-body-xs text-dark-1 tracking-wide uppercase">
                Client Satisfaction
              </p>
            </li>
          </ul>
        </div>

        <!-- Right: narrative paragraphs -->
        <div
          data-animate-stagger
          class="gap-el-xl md:pt-el-xl flex flex-col md:col-span-6 md:col-start-7"
        >
          <p class="text-body-md text-dark-1">
            Founded in the heart of Mount Washington, Reliable Inspections began
            with a singular vision: to bring architectural precision to the
            residential inspection industry. Our founder, a veteran structural
            consultant, noticed a gap between standard municipal checklists and
            the comprehensive understanding homeowners actually needed.
          </p>
          <p class="text-body-md text-dark-1">
            What started as a one-man operation has grown into Kentucky's
            premier inspection firm. We've built our reputation on the belief
            that quality shouldn't be a premium service — it should be the
            standard. We don't just look for problems; we look for solutions and
            longevity.
          </p>
          <p class="text-body-md text-dark-1">
            Today, our commitment to quality remains unshakable. Whether it's a
            historic Victorian in Louisville or a new build in Bowling Green, we
            approach every square foot with the same attention to detail.
          </p>
        </div>
      </div>
    </section>

    <!-- Core Principles -->
    <section class="px-page py-section-md">
      <div class="contained">
        <div data-animate class="mb-section-sm text-center">
          <GoldLabel text="Core Principles" />
          <h2 class="text-title-md font-semibold">
            Built on Foundational Values
          </h2>
        </div>
        <ul class="gap-gutter grid md:grid-cols-3">
          <li
            data-animate-stagger
            data-animate
            class="border-light-3 p-el-xl rounded-xl border"
          >
            <IntegrityIcon class="text-blue-2 mb-el-xl size-12" />
            <h3 class="text-body-lg mb-el-md font-semibold">Integrity</h3>
            <p class="text-body-sm text-dark-1">
              Our reports are unbiased and thorough. We answer only to our
              clients, ensuring transparency in every discovery, no matter how
              small.
            </p>
          </li>
          <li
            data-animate-stagger
            data-animate
            class="border-light-3 p-el-xl rounded-xl border"
          >
            <PrecisionIcon class="text-blue-2 mb-el-xl size-12" />
            <h3 class="text-body-lg mb-el-md font-semibold">Precision</h3>
            <p class="text-body-sm text-dark-1">
              Our reports are unbiased and thorough. We answer only to our
              clients, ensuring transparency in every discovery, no matter how
              small.
            </p>
          </li>
          <li
            data-animate-stagger
            data-animate
            class="border-light-3 p-el-xl rounded-xl border"
          >
            <CareIcon class="text-blue-2 mb-el-xl size-12" />
            <h3 class="text-body-lg mb-el-md font-semibold">Client Care</h3>
            <p class="text-body-sm text-dark-1">
              Our reports are unbiased and thorough. We answer only to our
              clients, ensuring transparency in every discovery, no matter how
              small.
            </p>
          </li>
        </ul>
      </div>
    </section>

    <CtaSection />
    <FaqSection />
  </main>
</Layout>
